// Plan Dashboard - Logic & Charts
let planData = null;

// Initialize
async function init() {
  await loadData();
  initTheme();
  initClock();
  renderHeader();
  renderStats();
  renderAlerts();
  renderWaves();
  renderGantt();
  renderQuality();
  initExport();
}

// Load plan.json
async function loadData() {
  try {
    const res = await fetch('plan.json');
    planData = await res.json();
  } catch (e) {
    console.error('Failed to load plan.json', e);
    document.body.innerHTML = '<div style="padding:40px;text-align:center;color:#f87171;">Error loading plan.json</div>';
  }
}

// Theme
function initTheme() {
  const saved = localStorage.getItem('dashboard-theme');
  const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const theme = saved || 'system';
  applyTheme(theme === 'system' ? (systemDark ? 'dark' : 'light') : theme);
  document.querySelectorAll('.theme-btn').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.theme === theme);
    btn.onclick = () => setTheme(btn.dataset.theme);
  });
}
function setTheme(theme) {
  localStorage.setItem('dashboard-theme', theme);
  const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  applyTheme(theme === 'system' ? (systemDark ? 'dark' : 'light') : theme);
  document.querySelectorAll('.theme-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.theme === theme));
}
function applyTheme(theme) { document.documentElement.dataset.theme = theme; }

// Clock
function initClock() {
  const update = () => {
    const now = new Date();
    document.getElementById('clock').textContent = now.toLocaleString('it-IT', {
      day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit', timeZone: 'Europe/Rome'
    }) + ' CET';
  };
  update();
  setInterval(update, 1000);
}

// Render Header
function renderHeader() {
  document.getElementById('projectName').textContent = planData.meta.project;
  document.getElementById('planName').textContent = planData.meta.plan;
  document.getElementById('branchName').textContent = planData.meta.branch;
  // Sidebar nav
  const nav = document.getElementById('filesNav');
  nav.innerHTML = Object.entries(planData.files).map(([key, path]) =>
    `<a class="nav-item" href="${path}" target="_blank"><span class="icon">📄</span>${key}<span class="badge">${path.split('/').pop()}</span></a>`
  ).join('');
}

// Render Stats
function renderStats() {
  const p = planData.progress;
  document.getElementById('statProgress').textContent = p.percent + '%';
  document.getElementById('statProgressSub').textContent = `${p.done}/${p.total} tasks`;
  const doneWaves = planData.waves.filter(w => w.status === 'done').length;
  document.getElementById('statWaves').textContent = `${doneWaves}/${planData.waves.length}`;
  const inProgress = planData.waves.find(w => w.status === 'in_progress');
  document.getElementById('statWavesSub').textContent = inProgress ? `${inProgress.id} in progress` : 'All done';
  const bugs = planData.bugs;
  document.getElementById('statBugs').textContent = bugs.p0.fixed + bugs.p1.fixed + bugs.p2.fixed;
  document.getElementById('statBugsSub').textContent = '100% resolved';
  const blockers = planData.alerts.filter(a => a.type === 'blocker').length;
  document.getElementById('statBlockers').textContent = blockers;
  document.getElementById('statBlockersSub').textContent = blockers > 0 ? planData.alerts.find(a => a.type === 'blocker')?.title : 'None';
  document.getElementById('statBlockersSub').className = 'stat-sub ' + (blockers > 0 ? 'warning' : 'success');
  // Progress bar
  document.getElementById('progressFill').style.width = p.percent + '%';
  document.getElementById('progressLabel').textContent = `${p.percent}% Complete (${p.done}/${p.total})`;
}

// Render Alerts
function renderAlerts() {
  const container = document.getElementById('alertsContainer');
  const icons = { blocker: '🚫', warning: '⏳', info: '🤖' };
  container.innerHTML = planData.alerts.map(a => `
    <div class="alert ${a.type}">
      <div class="alert-icon">${icons[a.type] || '📌'}</div>
      <div class="alert-content"><h4>${a.title}</h4><p>${a.desc}</p></div>
    </div>
  `).join('');
}

// Render Waves
function renderWaves() {
  const container = document.getElementById('wavesContainer');
  container.innerHTML = planData.waves.map(wave => {
    const pct = Math.round((wave.tasks.done / wave.tasks.total) * 100);
    const items = (wave.items || []).map(item => `
      <div class="task-item">
        <span class="task-id">${item.id}</span>
        <span class="task-title">
          ${item.priority ? `<span class="task-priority ${item.priority}">${item.priority}</span>` : ''}
          ${item.title}
        </span>
        <span class="task-by">${item.by || ''}</span>
        <span class="task-status"><span class="status-badge ${item.status}">${item.status === 'done' ? '✓' : item.status === 'skipped' ? '–' : '○'}</span></span>
      </div>
    `).join('');
    return `
      <div class="wave-row" data-wave="${wave.id}">
        <div class="wave-header" onclick="toggleWave('${wave.id}')">
          <span class="wave-id">${wave.id}</span>
          <span class="wave-name">${wave.name}</span>
          <span class="wave-assignee">${wave.assignee}</span>
          <span class="wave-progress-cell">
            <div class="wave-progress-bar"><div class="wave-progress-fill" style="width:${pct}%"></div></div>
          </span>
          <span class="wave-tasks">${wave.tasks.done}/${wave.tasks.total}</span>
          <span class="wave-expand">▼</span>
        </div>
        <div class="wave-details">${items || '<p style="color:var(--text-muted)">No tasks</p>'}</div>
      </div>
    `;
  }).join('');
}
function toggleWave(id) {
  document.querySelector(`.wave-row[data-wave="${id}"]`).classList.toggle('expanded');
}

// Render Gantt
function renderGantt() {
  const series = planData.waves.map(w => ({
    x: w.name,
    y: [
      new Date(w.start).getTime(),
      w.end ? new Date(w.end).getTime() : Date.now()
    ],
    fillColor: w.status === 'done' ? '#4ade80' : w.status === 'in_progress' ? '#6366f1' : '#8b8b9e'
  }));
  const options = {
    series: [{ data: series }],
    chart: { type: 'rangeBar', height: 200, toolbar: { show: false }, background: 'transparent' },
    plotOptions: { bar: { horizontal: true, borderRadius: 4, rangeBarGroupRows: true } },
    xaxis: { type: 'datetime', labels: { style: { colors: '#8b8b9e' }, datetimeFormatter: { hour: 'HH:mm' } } },
    yaxis: { labels: { style: { colors: '#8b8b9e' } } },
    grid: { borderColor: 'rgba(255,255,255,0.1)' },
    tooltip: { theme: 'dark', x: { format: 'HH:mm' } },
    legend: { show: false }
  };
  new ApexCharts(document.getElementById('ganttChart'), options).render();
}

// Render Quality
function renderQuality() {
  const container = document.getElementById('qualityContainer');
  const icons = { pass: '✓', fail: '✗', pending: '⏳' };
  container.innerHTML = planData.quality.map(q => `
    <div class="gate">
      <div class="gate-icon ${q.status}">${icons[q.status]}</div>
      <div class="gate-text"><div class="gate-title">${q.name}</div><div class="gate-sub">${q.detail}</div></div>
    </div>
  `).join('');
}

// Export
function initExport() {
  document.getElementById('exportBtn').onclick = () => document.getElementById('exportModal').classList.add('active');
  document.getElementById('closeModal').onclick = () => document.getElementById('exportModal').classList.remove('active');
  document.getElementById('exportPng').onclick = exportPng;
  document.getElementById('exportAdo').onclick = exportAzureDevOps;
  document.getElementById('exportModal').onclick = e => { if (e.target.id === 'exportModal') e.target.classList.remove('active'); };
}

async function exportPng() {
  const el = document.querySelector('.main');
  const canvas = await html2canvas(el, { backgroundColor: '#0f0f1a', scale: 2 });
  const link = document.createElement('a');
  link.download = `${planData.meta.project}-dashboard-${new Date().toISOString().slice(0,10)}.png`;
  link.href = canvas.toDataURL();
  link.click();
  document.getElementById('exportModal').classList.remove('active');
}

function exportAzureDevOps() {
  const items = [];
  planData.waves.forEach(wave => {
    (wave.items || []).forEach(task => {
      if (task.status !== 'done' && task.status !== 'skipped') {
        items.push({
          'Work Item Type': task.priority ? 'Bug' : 'Task',
          'Title': `[${wave.id}] ${task.title}`,
          'Assigned To': task.by || wave.assignee,
          'State': task.status === 'in_progress' ? 'Active' : 'New',
          'Priority': task.priority === 'P0' ? 1 : task.priority === 'P1' ? 2 : task.priority === 'P2' ? 3 : 4,
          'Tags': `${planData.meta.project};${wave.id}`,
          'Description': `Wave: ${wave.name}\nFiles: ${(task.files || []).join(', ')}`
        });
      }
    });
  });
  if (items.length === 0) { alert('No pending items to export!'); return; }
  // CSV
  const headers = Object.keys(items[0]);
  const csv = [headers.join(','), ...items.map(i => headers.map(h => `"${(i[h]+'').replace(/"/g,'""')}"`).join(','))].join('\n');
  const blob = new Blob([csv], { type: 'text/csv' });
  const link = document.createElement('a');
  link.download = `${planData.meta.project}-backlog-${new Date().toISOString().slice(0,10)}.csv`;
  link.href = URL.createObjectURL(blob);
  link.click();
  document.getElementById('exportModal').classList.remove('active');
}

// Init on load
document.addEventListener('DOMContentLoaded', init);
