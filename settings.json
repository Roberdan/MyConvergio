{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "BASH_DEFAULT_TIMEOUT_MS": "60000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "NODE_OPTIONS": "--max-old-space-size=16384",
    "UV_THREADPOOL_SIZE": "12",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "mcp__codegraph__*",
      "Bash(npm *)",
      "Bash(git *)",
      "mcp__codegraph__codegraph_search",
      "mcp__codegraph__codegraph_context",
      "mcp__codegraph__codegraph_callers",
      "mcp__codegraph__codegraph_callees",
      "mcp__codegraph__codegraph_impact",
      "mcp__codegraph__codegraph_node",
      "mcp__codegraph__codegraph_status"
    ],
    "deny": [],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/gh-auto-token.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/warn-bash-antipatterns.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/prefer-ci-summary.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/warn-infra-plan-drift.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce-plan-db-safe.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-file-lock.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce-plan-edit.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "PreCommit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/secret-scanner.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/env-vault-guard.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-plan-mode.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce-line-limit.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-format.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-settings.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-before-claim.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Grep|Glob",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "~/.claude/hooks/advisory-suggest-alternatives.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "codegraph mark-dirty",
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/inject-agent-context.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/preserve-context.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Setup": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/context-audit.sh --maintenance",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/version-check.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/model-registry-refresh.sh",
            "timeout": 20
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-end-tokens.sh",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-file-unlock.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-reaper.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "codegraph sync-if-dirty"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree-setup.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree-teardown.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/track-tokens.sh teammate-idle",
            "async": true
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/track-tokens.sh task-completed",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir'); model=$(echo \"$input\" | jq -r '.model.display_name'); ctx=$(echo \"$input\" | jq -r '.context_window.used_percentage // 0' | cut -d. -f1); ctxmax=$(echo \"$input\" | jq -r '.context_window.total // 200000'); branch=''; if [ -d \"$cwd/.git\" ]; then cd \"$cwd\" 2>/dev/null && branch=$(git branch --show-current 2>/dev/null); fi; cost=''; if command -v awk >/dev/null 2>&1; then toks=$(awk \"BEGIN{printf \\\"%d\\\", $ctxmax * $ctx / 100}\"); case \"$model\" in *Opus*) cost=$(awk \"BEGIN{printf \\\"$%.2f\\\", $toks*0.000015 + $toks*0.25*0.000075}\");; *) cost=$(awk \"BEGIN{printf \\\"$%.2f\\\", $toks*0.000003 + $toks*0.25*0.000015}\");; esac; fi; printf '\\033[2;38;5;117m%s\\033[0m' \"$(basename \"$cwd\")${branch:+ ($branch)} • $model • ctx:${ctx}%${cost:+ ~$cost}\""
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "language": "italian",
  "autoUpdatesChannel": "latest",
  "plansDirectory": "~/.claude/plans",
  "skipDangerousModePermissionPrompt": true
}
