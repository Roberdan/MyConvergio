<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Plan Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="dashboard.css">
  <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
  <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
</head>
<body>
  <div class="dashboard">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="logo">
        <div class="logo-icon">📊</div>
        <h1 id="projectName">Project</h1>
      </div>

      <div class="nav-section">
        <div class="nav-label">Navigation</div>
        <div class="nav-item active"><span class="icon">🏠</span>Dashboard</div>
        <div class="nav-item"><span class="icon">📋</span>Waves<span class="badge" id="wavesBadge">5</span></div>
        <div class="nav-item"><span class="icon">🐛</span>Bugs<span class="badge" id="bugsBadge">21</span></div>
        <div class="nav-item"><span class="icon">✅</span>Quality</div>
      </div>

      <div class="nav-section">
        <div class="nav-label">Files</div>
        <div id="filesNav"></div>
      </div>

      <div class="sidebar-footer">
        <div class="nav-label">Theme</div>
        <div class="theme-toggle">
          <button class="theme-btn" data-theme="light">☀️</button>
          <button class="theme-btn" data-theme="dark">🌙</button>
          <button class="theme-btn" data-theme="system">💻</button>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main">
      <!-- Header -->
      <div class="header">
        <div class="header-left">
          <h2 id="planName">Plan Name</h2>
          <div class="breadcrumb">
            <span>Branch:</span>
            <a href="#" id="branchName">main</a>
            <span>•</span>
            <span>Mode: PLAN → EXECUTE → VERIFY → CLOSE</span>
          </div>
        </div>
        <div class="header-right">
          <div class="live-badge"><div class="live-dot"></div>LIVE</div>
          <div class="clock" id="clock">Loading...</div>
          <button class="export-btn" id="exportBtn">📤 Export</button>
        </div>
      </div>

      <!-- Stats Row -->
      <div class="grid-4">
        <div class="card stat-card">
          <div class="stat-value" id="statProgress">--%</div>
          <div class="stat-label">Progress</div>
          <div class="stat-sub success" id="statProgressSub">--/-- tasks</div>
        </div>
        <div class="card stat-card">
          <div class="stat-value" id="statWaves">-/-</div>
          <div class="stat-label">Waves Done</div>
          <div class="stat-sub" id="statWavesSub">--</div>
        </div>
        <div class="card stat-card">
          <div class="stat-value" id="statBugs">--</div>
          <div class="stat-label">Bugs Fixed</div>
          <div class="stat-sub success" id="statBugsSub">--</div>
        </div>
        <div class="card stat-card">
          <div class="stat-value" id="statBlockers">-</div>
          <div class="stat-label">Blockers</div>
          <div class="stat-sub" id="statBlockersSub">--</div>
        </div>
      </div>

      <!-- Progress + Gantt -->
      <div class="grid-2">
        <div class="card card-glow">
          <div class="card-header">
            <h3>Timeline (Gantt)</h3>
            <span style="color:var(--text-muted);font-size:12px;">Hover for details</span>
          </div>
          <div class="progress-bar" style="margin-bottom:16px;">
            <div class="progress-fill" id="progressFill" style="width:0%"></div>
          </div>
          <div style="font-size:12px;color:var(--text-muted);margin-bottom:12px;" id="progressLabel">Loading...</div>
          <div id="ganttChart"></div>
        </div>
        <div class="card">
          <div class="card-header"><h3>Alerts</h3></div>
          <div id="alertsContainer"></div>
        </div>
      </div>

      <!-- Waves + Quality -->
      <div class="grid-2">
        <div class="card">
          <div class="card-header">
            <h3>Wave Breakdown</h3>
            <span style="color:var(--text-muted);font-size:12px;">Click to expand</span>
          </div>
          <div id="wavesContainer"></div>
        </div>
        <div class="card">
          <div class="card-header"><h3>Quality Gates</h3></div>
          <div id="qualityContainer"></div>
        </div>
      </div>

      <!-- Footer -->
      <div style="text-align:center;color:var(--text-muted);font-size:11px;margin-top:24px;padding-top:16px;border-top:1px solid var(--border);">
        Plan Dashboard • Data-driven from plan.json • Auto-refresh: F5
      </div>
    </main>
  </div>

  <!-- Export Modal -->
  <div class="modal-overlay" id="exportModal">
    <div class="modal">
      <h3>Export Dashboard</h3>
      <button class="modal-btn" id="exportPng">📸 Export as PNG (Screenshot)</button>
      <button class="modal-btn" id="exportAdo">📋 Export to Azure DevOps (CSV)</button>
      <button class="modal-close" id="closeModal">Cancel</button>
    </div>
  </div>

  <script src="dashboard.js"></script>
</body>
</html>
