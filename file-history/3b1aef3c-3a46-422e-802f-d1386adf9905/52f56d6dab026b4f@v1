<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ConvergioEdu Sprint Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #16213e 100%);
      min-height: 100vh; color: #fff; padding: 24px;
    }
    .dashboard { max-width: 1400px; margin: 0 auto; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .header h1 { font-size: 24px; font-weight: 600; }
    .header .status { display: flex; align-items: center; gap: 8px; }
    .header .status-dot { width: 10px; height: 10px; border-radius: 50%; background: #00d4aa; animation: pulse 2s infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
    .header .time { color: #8b8b9e; font-size: 14px; }

    /* Cards */
    .card {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 16px; padding: 20px;
    }
    .card-glow { box-shadow: 0 0 40px rgba(99, 102, 241, 0.15); }

    /* Grid */
    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
    .grid-2 { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; margin-bottom: 24px; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px; }

    /* Stat Cards */
    .stat-card { text-align: center; }
    .stat-value { font-size: 36px; font-weight: 700; background: linear-gradient(135deg, #6366f1, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .stat-label { color: #8b8b9e; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }
    .stat-sub { color: #4ade80; font-size: 14px; margin-top: 8px; }
    .stat-sub.warning { color: #fbbf24; }
    .stat-sub.danger { color: #f87171; }

    /* Progress Bar */
    .progress-container { margin: 16px 0; }
    .progress-bar { height: 12px; background: rgba(255,255,255,0.1); border-radius: 6px; overflow: hidden; }
    .progress-fill { height: 100%; background: linear-gradient(90deg, #6366f1, #a855f7, #ec4899); border-radius: 6px; transition: width 0.5s ease; }
    .progress-label { display: flex; justify-content: space-between; font-size: 12px; color: #8b8b9e; margin-top: 8px; }

    /* Waves Table */
    .waves-table { width: 100%; border-collapse: collapse; }
    .waves-table th { text-align: left; color: #8b8b9e; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; padding: 12px 8px; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .waves-table td { padding: 12px 8px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .wave-status { display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 500; }
    .wave-status.done { background: rgba(74, 222, 128, 0.2); color: #4ade80; }
    .wave-status.progress { background: rgba(99, 102, 241, 0.2); color: #818cf8; }
    .wave-status.pending { background: rgba(139, 139, 158, 0.2); color: #8b8b9e; }
    .wave-progress { width: 100px; height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden; }
    .wave-progress-fill { height: 100%; background: linear-gradient(90deg, #6366f1, #a855f7); border-radius: 3px; }

    /* Quality Gates */
    .gate { display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 8px; margin-bottom: 8px; background: rgba(255,255,255,0.03); }
    .gate-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 16px; }
    .gate-icon.pass { background: rgba(74, 222, 128, 0.2); }
    .gate-icon.fail { background: rgba(248, 113, 113, 0.2); }
    .gate-icon.pending { background: rgba(251, 191, 36, 0.2); }
    .gate-text { flex: 1; }
    .gate-title { font-weight: 500; font-size: 14px; }
    .gate-sub { font-size: 12px; color: #8b8b9e; }

    /* Alerts */
    .alert { display: flex; align-items: center; gap: 12px; padding: 16px; border-radius: 12px; margin-bottom: 12px; }
    .alert.blocker { background: linear-gradient(135deg, rgba(248, 113, 113, 0.2), rgba(248, 113, 113, 0.05)); border-left: 3px solid #f87171; }
    .alert.warning { background: linear-gradient(135deg, rgba(251, 191, 36, 0.2), rgba(251, 191, 36, 0.05)); border-left: 3px solid #fbbf24; }
    .alert.info { background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(99, 102, 241, 0.05)); border-left: 3px solid #6366f1; }
    .alert-icon { font-size: 20px; }
    .alert-content h4 { font-size: 14px; font-weight: 600; }
    .alert-content p { font-size: 12px; color: #8b8b9e; margin-top: 2px; }

    /* Chart container */
    #velocityChart { height: 200px; }

    /* Bug Priority */
    .bug-priority { display: flex; gap: 16px; margin-top: 16px; }
    .bug-item { flex: 1; text-align: center; padding: 16px; border-radius: 12px; background: rgba(255,255,255,0.03); }
    .bug-count { font-size: 28px; font-weight: 700; }
    .bug-count.p0 { color: #f87171; }
    .bug-count.p1 { color: #fbbf24; }
    .bug-count.p2 { color: #4ade80; }
    .bug-label { font-size: 11px; color: #8b8b9e; text-transform: uppercase; margin-top: 4px; }

    /* Footer */
    .footer { text-align: center; color: #8b8b9e; font-size: 12px; margin-top: 24px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.1); }
  </style>
</head>
<body>
  <div class="dashboard">
    <!-- Header -->
    <div class="header">
      <h1>ConvergioEdu Sprint Dashboard</h1>
      <div class="status">
        <div class="status-dot"></div>
        <span>LIVE</span>
        <span class="time">3 Gennaio 2026, 20:30 CET</span>
      </div>
    </div>

    <!-- Stats Row -->
    <div class="grid-4">
      <div class="card stat-card">
        <div class="stat-value">87%</div>
        <div class="stat-label">Progress</div>
        <div class="stat-sub">54/62 tasks</div>
      </div>
      <div class="card stat-card">
        <div class="stat-value">4/5</div>
        <div class="stat-label">Waves Done</div>
        <div class="stat-sub">W5 in progress</div>
      </div>
      <div class="card stat-card">
        <div class="stat-value">21</div>
        <div class="stat-label">Bugs Fixed</div>
        <div class="stat-sub">100% resolved</div>
      </div>
      <div class="card stat-card">
        <div class="stat-value">1</div>
        <div class="stat-label">Blockers</div>
        <div class="stat-sub warning">PR #106</div>
      </div>
    </div>

    <!-- Progress + Alerts -->
    <div class="grid-2">
      <div class="card card-glow">
        <h3 style="margin-bottom: 16px;">Overall Progress</h3>
        <div class="progress-container">
          <div class="progress-bar"><div class="progress-fill" style="width: 87%"></div></div>
          <div class="progress-label"><span>Started: 17:15</span><span>87% Complete</span><span>ETA: W5 Thor QA</span></div>
        </div>
        <div id="velocityChart"></div>
      </div>
      <div class="card">
        <h3 style="margin-bottom: 16px;">Alerts</h3>
        <div class="alert blocker">
          <div class="alert-icon">🚫</div>
          <div class="alert-content">
            <h4>PR #106 NOT Merging</h4>
            <p>6/10 QA failures - staying on development</p>
          </div>
        </div>
        <div class="alert warning">
          <div class="alert-icon">⏳</div>
          <div class="alert-content">
            <h4>Wave 5 Pending</h4>
            <p>Thor QA + Merge waiting</p>
          </div>
        </div>
        <div class="alert info">
          <div class="alert-icon">🤖</div>
          <div class="alert-content">
            <h4>Claude-A Active</h4>
            <p>Completed W1-W4, awaiting W5</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Waves + Quality Gates -->
    <div class="grid-2">
      <div class="card">
        <h3 style="margin-bottom: 16px;">Wave Breakdown</h3>
        <table class="waves-table">
          <thead><tr><th>Wave</th><th>Description</th><th>Status</th><th>Progress</th><th>Tasks</th></tr></thead>
          <tbody>
            <tr><td><strong>W0</strong></td><td>QA + Plan Update</td><td><span class="wave-status done">✓ Done</span></td><td><div class="wave-progress"><div class="wave-progress-fill" style="width:100%"></div></div></td><td>3/3</td></tr>
            <tr><td><strong>W1-2</strong></td><td>Bug Fixes (P0/P1/P2)</td><td><span class="wave-status done">✓ Done</span></td><td><div class="wave-progress"><div class="wave-progress-fill" style="width:100%"></div></div></td><td>21/21</td></tr>
            <tr><td><strong>W3</strong></td><td>Welcome Experience</td><td><span class="wave-status done">✓ Done</span></td><td><div class="wave-progress"><div class="wave-progress-fill" style="width:100%"></div></div></td><td>9/9</td></tr>
            <tr><td><strong>W4</strong></td><td>Supporti Consolidation</td><td><span class="wave-status done">✓ Done</span></td><td><div class="wave-progress"><div class="wave-progress-fill" style="width:100%"></div></div></td><td>11/11</td></tr>
            <tr><td><strong>W5</strong></td><td>Thor QA + Merge</td><td><span class="wave-status progress">◉ Progress</span></td><td><div class="wave-progress"><div class="wave-progress-fill" style="width:11%"></div></div></td><td>1/9</td></tr>
          </tbody>
        </table>
      </div>
      <div class="card">
        <h3 style="margin-bottom: 16px;">Quality Gates</h3>
        <div class="gate"><div class="gate-icon pass">✓</div><div class="gate-text"><div class="gate-title">TypeCheck</div><div class="gate-sub">Passing</div></div></div>
        <div class="gate"><div class="gate-icon pass">✓</div><div class="gate-text"><div class="gate-title">Lint</div><div class="gate-sub">0 warnings</div></div></div>
        <div class="gate"><div class="gate-icon pass">✓</div><div class="gate-text"><div class="gate-title">Build</div><div class="gate-sub">Successful</div></div></div>
        <div class="gate"><div class="gate-icon pending">⏳</div><div class="gate-text"><div class="gate-title">Thor Validation</div><div class="gate-sub">Pending W5</div></div></div>
        <div class="gate"><div class="gate-icon pending">⏳</div><div class="gate-text"><div class="gate-title">Roberto Approval</div><div class="gate-sub">Awaiting review</div></div></div>
      </div>
    </div>

    <!-- Bug Priority Breakdown -->
    <div class="card" style="margin-bottom: 24px;">
      <h3 style="margin-bottom: 8px;">Bug Priority Breakdown</h3>
      <p style="color: #8b8b9e; font-size: 12px; margin-bottom: 16px;">All 21 bugs fixed in Wave 1-2</p>
      <div class="bug-priority">
        <div class="bug-item"><div class="bug-count p0">7</div><div class="bug-label">P0 Critical</div><div style="color:#4ade80;font-size:11px;margin-top:4px;">✓ Fixed</div></div>
        <div class="bug-item"><div class="bug-count p1">9</div><div class="bug-label">P1 High</div><div style="color:#4ade80;font-size:11px;margin-top:4px;">✓ Fixed</div></div>
        <div class="bug-item"><div class="bug-count p2">5</div><div class="bug-label">P2 Medium</div><div style="color:#4ade80;font-size:11px;margin-top:4px;">✓ Fixed</div></div>
      </div>
    </div>

    <div class="footer">
      ConvergioEdu Sprint Dashboard • Auto-generated from TODAY.md • Last refresh: <span id="lastRefresh"></span>
    </div>
  </div>

  <script>
    // Update timestamp
    document.getElementById('lastRefresh').textContent = new Date().toLocaleString('it-IT', { timeZone: 'Europe/Rome' });

    // Velocity Chart
    var options = {
      series: [{ name: 'Tasks Completed', data: [3, 24, 33, 44, 54] }],
      chart: { type: 'area', height: 180, toolbar: { show: false }, background: 'transparent' },
      stroke: { curve: 'smooth', width: 3 },
      fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.5, opacityTo: 0.1, stops: [0, 90, 100] } },
      colors: ['#6366f1'],
      xaxis: { categories: ['W0', 'W1-2', 'W3', 'W4', 'W5'], labels: { style: { colors: '#8b8b9e' } }, axisBorder: { show: false }, axisTicks: { show: false } },
      yaxis: { labels: { style: { colors: '#8b8b9e' } }, max: 62 },
      grid: { borderColor: 'rgba(255,255,255,0.1)', strokeDashArray: 3 },
      tooltip: { theme: 'dark' },
      dataLabels: { enabled: false }
    };
    new ApexCharts(document.querySelector("#velocityChart"), options).render();
  </script>
</body>
</html>
