{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/enforce-standards.sh",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "bash": "~/.copilot/hooks/worktree-guard.sh",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "bash": "~/.copilot/hooks/session-file-lock.sh",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/enforce-line-limit.sh",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/session-task-recovery.sh",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": "~/.copilot/hooks/session-tokens.sh",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "~/.copilot/hooks/session-file-unlock.sh",
        "timeoutSec": 10
      }
    ]
  }
}
