<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Plan Dashboard</title>
  <link rel="stylesheet" href="dashboard.css">
  <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
</head>
<body>
  <!-- Top Navigation -->
  <nav class="top-nav">
    <div class="logo">
      <div class="logo-dot"></div>
      <span id="projectName">Voltrex</span>
    </div>
    <div class="nav-menu">
      <a href="#" class="active">Dashboard</a>
      <a href="#">Waves</a>
      <a href="#">Bugs</a>
      <a href="#">Activity</a>
      <a href="#">Agents</a>
      <a href="#">More</a>
    </div>
    <div class="nav-right">
      <div class="nav-badge green" id="throughputBadge">87%</div>
      <div class="nav-badge" id="ownerBadge">Roberto</div>
      <button class="nav-btn" id="exportBtn">Export</button>
    </div>
  </nav>

  <div class="main-layout">
    <!-- Left Sidebar -->
    <aside class="sidebar-left">
      <div class="sidebar-icon active">&#x1F4CA;</div>
      <div class="sidebar-icon">&#x270F;</div>
      <div class="sidebar-icon">&#x2702;</div>
      <div class="sidebar-icon">&#x1F4CB;</div>
      <div class="sidebar-icon">&#x2B50;</div>
      <div class="sidebar-icon">&#x1F41B;</div>
      <div class="sidebar-icon">&#x2699;</div>
    </aside>

    <!-- Main Content -->
    <main class="content">
      <!-- Stats Header -->
      <div class="stats-header">
        <h2 id="planLabel">ConvergioEdu</h2>
      </div>

      <!-- Stats Row -->
      <div class="stats-row">
        <div class="stat-item">
          <div class="stat-label">Tasks Done</div>
          <div class="stat-value green" id="tasksDone">54</div>
        </div>
        <div class="stat-item">
          <div class="stat-label">Velocity</div>
          <div class="stat-value white" id="velocity">12.5/h</div>
        </div>
        <div class="stat-item">
          <div class="stat-label">Cycle Time</div>
          <div class="stat-value white" id="cycleTime">8.5 min</div>
        </div>
        <div class="stat-item">
          <div class="stat-label">Bugs Fixed</div>
          <div class="stat-value white" id="bugsFixed">21/21</div>
        </div>
        <div class="stat-item">
          <div class="stat-label">Quality Score</div>
          <div class="stat-value white" id="quality">98.2%</div>
        </div>
      </div>

      <!-- Epoch Bar -->
      <div class="epoch-bar">
        <div class="epoch-left">
          <div class="epoch-icon">&#x1F4C5;</div>
          <div class="epoch-info">
            <div class="epoch-label">Current Wave</div>
            <div class="epoch-value" id="currentWave">Wave 5 - Thor QA</div>
          </div>
        </div>
        <div class="epoch-right">
          <div class="epoch-dates" id="epochDates">2026.01.03 17:15 - 2026.01.03 23:30</div>
          <div class="epoch-countdown" id="countdown">1h 00m left</div>
        </div>
      </div>

      <!-- Chart Section -->
      <div class="chart-section">
        <div style="display:flex;align-items:center;margin-bottom:16px;">
          <div class="chart-tabs">
            <div class="chart-tab active">Progress</div>
            <div class="chart-tab">Burndown</div>
          </div>
          <div class="chart-legend">
            <span class="btc">Done: 54</span>
            <span class="etc">Target: 62</span>
            <span>Remaining: 8</span>
          </div>
          <div class="chart-filter">&#x1F4C5; All time</div>
        </div>
        <div id="mainChart"></div>
      </div>

      <!-- Traders/Agents Section -->
      <div class="traders-section">
        <div class="traders-header">Agents Performance</div>
        <div class="traders-grid" id="agentsGrid"></div>
      </div>
    </main>

    <!-- Right Sidebar -->
    <aside class="sidebar-right">
      <div class="sidebar-tabs">
        <div class="sidebar-tab active">PR STATUS</div>
        <div class="sidebar-tab">CI/CD</div>
      </div>

      <div class="sidebar-stats">
        <div>
          <div class="sidebar-stat-label">Additions</div>
          <div class="sidebar-stat-value" id="prAdditions">+890</div>
        </div>
        <div>
          <div class="sidebar-stat-label">Deletions</div>
          <div class="sidebar-stat-value green" id="prDeletions">-234</div>
        </div>
      </div>

      <div class="sidebar-available">PR #<span id="prNumber">106</span> - <span id="prFiles">23</span> files</div>

      <div class="input-group">
        <label>PR Title</label>
        <div class="input-row">
          <input type="text" id="prTitle" value="feat: Sprint 3 Gennaio" readonly>
        </div>
      </div>

      <div class="slider-group">
        <div class="slider-header">
          <span>Progress</span>
          <span id="prProgress">87%</span>
        </div>
        <input type="range" class="slider" value="87" disabled>
        <div class="slider-labels">
          <span>0</span>
          <span>25</span>
          <span>50</span>
          <span>75</span>
          <span>100</span>
        </div>
      </div>

      <div class="info-row">
        <span>TypeCheck</span>
        <span class="green">Pass</span>
      </div>
      <div class="info-row">
        <span>Lint</span>
        <span class="green">Pass</span>
      </div>
      <div class="info-row">
        <span>Build</span>
        <span class="green">Pass</span>
      </div>
      <div class="info-row">
        <span>Tests</span>
        <span class="green">142/142</span>
      </div>
      <div class="info-row">
        <span>Thor QA</span>
        <span style="color:var(--orange)">Pending</span>
      </div>

      <button class="deposit-btn" id="viewPrBtn">View PR</button>

      <div class="about-tabs">
        <div class="about-tab active">Alerts</div>
        <div class="about-tab">Git</div>
      </div>

      <div class="leader-section">
        <div class="leader-label">Blocker</div>
        <div class="leader-info">
          <div class="leader-avatar" style="background:var(--red);"></div>
          <div>
            <div class="leader-name">PR #106 NOT Merging</div>
            <div class="leader-handle">6/10 QA failures</div>
          </div>
        </div>
      </div>

      <div class="description" id="alertDesc">
        Thor QA validation is pending. Wave 5 cannot complete until all quality gates pass.
      </div>

      <div class="contract">
        <span id="gitBranch">development</span>
        <button style="background:transparent;border:none;color:var(--text-muted);cursor:pointer;">&#x1F4CB;</button>
      </div>
    </aside>
  </div>

  <script src="dashboard.js"></script>
</body>
</html>
