# Claude Ecosystem Environment Variables
# Copy to .env and customize as needed

# Dashboard Configuration
# Default: http://localhost:8420
DASHBOARD_URL=http://localhost:8420
DASHBOARD_API=http://localhost:8420/api

# Grafana Configuration  
# Default: https://mirrorbuddy.grafana.net
GRAFANA_URL=https://mirrorbuddy.grafana.net
GRAFANA_API_KEY=

# GitHub Configuration (auto-detected from git remote)
# These are typically auto-detected but can be overridden
# GITHUB_ORG=
# GITHUB_REPO=
# GITHUB_URL=

# Vercel Configuration (managed by vercel-helper.sh)
# No hardcoded URLs - uses Vercel CLI

# Supabase Configuration (managed by supabase-helper.sh)
# No hardcoded URLs - uses Supabase CLI
