<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Plan Dashboard</title>
  <link rel="stylesheet" href="dashboard.css">
  <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
</head>
<body>
  <!-- Top Navigation -->
  <nav class="top-nav">
    <div class="logo">
      <div class="logo-dot"></div>
      <span id="projectName">ConvergioEdu</span>
    </div>
    <div class="nav-menu">
      <a href="#" class="active">Dashboard</a>
      <a href="#">Waves</a>
      <a href="#">&#x1F525; Bugs</a>
      <a href="#">&#x1F525; Activity</a>
      <a href="#">Agents</a>
      <a href="#">More &#x25BE;</a>
    </div>
    <div class="nav-right">
      <div class="nav-badge highlight" id="throughputBadge">87%</div>
      <div class="nav-badge" id="ownerBadge">&#x1F464; Roberto</div>
      <div class="nav-badge">&#x1F30D; IT</div>
      <div class="theme-selector">
        <select id="themeSelect">
          <option value="voltrex">Voltrex</option>
          <option value="midnight">Midnight</option>
          <option value="frost">Frost</option>
          <option value="dawn">Dawn</option>
        </select>
      </div>
      <button class="nav-btn" id="exportBtn">Export</button>
    </div>
  </nav>

  <!-- Main Layout -->
  <div class="main-wrap">
    <!-- Main Content -->
    <main class="main-content">
      <!-- Stats Label -->
      <div class="stats-label" id="planLabel">ConvergioEdu</div>

      <!-- Stats Row -->
      <div class="stats-row">
        <div class="stat-item">
          <div class="label">Tasks Done</div>
          <div class="value green" id="tasksDone">$54</div>
        </div>
        <div class="stat-item">
          <div class="label">Velocity</div>
          <div class="value" id="velocity">12.5/h</div>
        </div>
        <div class="stat-item">
          <div class="label">Cycle Time</div>
          <div class="value" id="cycleTime">8.5min</div>
        </div>
        <div class="stat-item">
          <div class="label">Bugs Fixed</div>
          <div class="value" id="bugsFixed">21/21</div>
        </div>
        <div class="stat-item">
          <div class="label">Quality Score</div>
          <div class="value" id="quality">98.2%</div>
        </div>
      </div>

      <!-- Epoch Bar -->
      <div class="epoch-bar">
        <div class="epoch-icon">&#x1F4C5;</div>
        <div class="epoch-info">
          <div class="label">Current Wave</div>
          <div class="value" id="currentWave">Wave 5</div>
        </div>
        <div class="epoch-progress">
          <div class="epoch-dates" id="epochDates">2026.01.03 17:15 &#8212; 2026.01.03 23:30</div>
          <div class="epoch-bar-track">
            <div class="epoch-bar-fill" id="epochFill" style="width: 83%;"></div>
          </div>
        </div>
        <div class="epoch-countdown" id="countdown">1h 00m left</div>
      </div>

      <!-- Chart Card -->
      <div class="chart-card">
        <div class="chart-header">
          <div class="chart-tabs">
            <div class="chart-tab active">Progress</div>
            <div class="chart-tab">Burndown</div>
          </div>
          <div class="chart-filter">&#x1F4C5; All time &#x25BE;</div>
        </div>
        <div class="chart-legend">
          <span><span class="orange">Done:</span> 54</span>
          <span><span class="purple">Target:</span> 62</span>
          <span>Remaining: 8</span>
          <span>Other: 0</span>
        </div>
        <!-- Floating chart tools -->
        <div class="chart-tools">
          <div class="chart-tool">&#x2795;</div>
          <div class="chart-tool">&#x270F;</div>
          <div class="chart-tool">&#x2702;</div>
          <div class="chart-tool">&#x2194;</div>
          <div class="chart-tool">&#x2B50;</div>
          <div class="chart-tool">&#x1F4CF;</div>
        </div>
        <div id="mainChart"></div>
      </div>

      <!-- Agents Section -->
      <div class="traders-section">
        <div class="traders-header">Agents Performance</div>
        <div class="traders-grid" id="agentsGrid"></div>
      </div>
    </main>

    <!-- Right Panel -->
    <aside class="right-panel">
      <!-- PR Card -->
      <div class="panel-card">
        <div class="panel-tabs">
          <div class="panel-tab active">PR STATUS</div>
          <div class="panel-tab">CI/CD</div>
        </div>

        <div class="panel-stats">
          <div class="panel-stat">
            <div class="label">Additions</div>
            <div class="value" id="prAdditions">+890</div>
          </div>
          <div class="panel-stat">
            <div class="label">All-time Merged</div>
            <div class="value green" id="prDeletions">-234</div>
          </div>
        </div>

        <div class="panel-available">PR #<span id="prNumber">106</span> - <span id="prFiles">23</span> files</div>

        <div class="input-group">
          <label>PR Title</label>
          <div class="input-row">
            <input type="text" id="prTitle" value="feat: Sprint 3 Gennaio" readonly>
            <button class="max-btn">OPEN</button>
          </div>
        </div>

        <div class="slider-group">
          <div class="slider-header">
            <span>Progress</span>
            <span id="sliderValue">87%</span>
          </div>
          <div class="slider-track">
            <div class="slider-thumb" id="sliderThumb" style="left: 87%;"></div>
          </div>
          <div class="slider-labels">
            <span>0</span>
            <span>25</span>
            <span>50</span>
            <span>75</span>
            <span>100</span>
          </div>
        </div>

        <div class="info-row">
          <span>TypeCheck</span>
          <span class="green">Pass</span>
        </div>
        <div class="info-row">
          <span>Lint</span>
          <span class="green">Pass</span>
        </div>
        <div class="info-row">
          <span>Build</span>
          <span class="green">Pass</span>
        </div>
        <div class="info-row">
          <span>Tests</span>
          <span class="green">142/142</span>
        </div>
        <div class="info-row">
          <span>Thor QA</span>
          <span class="orange">Pending</span>
        </div>

        <button class="action-btn" id="viewPrBtn">View PR</button>

        <div class="about-tabs">
          <div class="about-tab active">Alerts</div>
          <div class="about-tab">Git</div>
        </div>

        <div class="leader-section">
          <div class="leader-label">Blocker</div>
          <div class="leader-info">
            <div class="leader-avatar" style="background: var(--red);"></div>
            <div>
              <div class="leader-name" id="blockerTitle">PR #106 NOT Merging</div>
              <div class="leader-handle" id="blockerDesc">6/10 QA failures</div>
            </div>
          </div>
        </div>

        <div class="description" id="alertDesc">
          Thor QA validation is pending. Wave 5 cannot complete until all quality gates pass.
        </div>

        <div class="contract-box">
          <span id="gitBranch">development</span>
          <button>&#x1F4CB;</button>
        </div>
      </div>
    </aside>
  </div>

  <script src="dashboard.js"></script>
</body>
</html>
