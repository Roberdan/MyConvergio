import { test, expect, type Page, type ConsoleMessage } from '@playwright/test';

// ============================================================================
// CONFIGURATION — Replace these placeholders
// ============================================================================
const BASE_URL = '{{BASE_URL}}'; // e.g. 'http://localhost:5173'
const MAIN_ROUTES = [
  '{{ROUTE_1}}', // e.g. '/app'
  '{{ROUTE_2}}', // e.g. '/app/admin'
];
const DATA_TABLE_SELECTOR = '{{TABLE_SELECTOR}}'; // e.g. 'table tbody tr'
const SELECTOR_COMPONENT = '{{SELECTOR_COMPONENT}}'; // e.g. '[data-testid="studio-selector"]'
const CHAT_TRIGGER = '{{CHAT_TRIGGER}}'; // e.g. '[data-testid="chat-fab"]'

// ============================================================================
// CONSOLE ERROR COLLECTOR
// ============================================================================
const consoleErrors: string[] = [];

test.beforeEach(async ({ page }) => {
  consoleErrors.length = 0;
  page.on('console', (msg: ConsoleMessage) => {
    if (msg.type() === 'error') consoleErrors.push(msg.text());
  });
});

// ============================================================================
// 1. NAVIGATION SMOKE — No blank screens
// ============================================================================
test.describe('Navigation Smoke', () => {
  for (const route of MAIN_ROUTES) {
    test(`${route} loads with content`, async ({ page }) => {
      await page.goto(`${BASE_URL}${route}`);
      await page.waitForLoadState('networkidle');
      
      // Must NOT be a blank screen
      const bodyText = await page.locator('body').innerText();
      expect(bodyText.trim().length).toBeGreaterThan(10);
      
      // Must NOT show only loading spinners after networkidle
      const skeletons = await page.locator('[class*="skeleton"], [class*="loading"]').count();
      const totalElements = await page.locator('body > *').count();
      expect(totalElements).toBeGreaterThan(skeletons);
    });
  }
});

// ============================================================================
// 2. DATA VALIDATION — Real data present
// ============================================================================
test.describe('Data Validation', () => {
  test('data table has rows', async ({ page }) => {
    await page.goto(`${BASE_URL}${MAIN_ROUTES[0]}`);
    await page.waitForLoadState('networkidle');
    
    const rows = page.locator(DATA_TABLE_SELECTOR);
    await expect(rows.first()).toBeVisible({ timeout: 10000 });
    expect(await rows.count()).toBeGreaterThan(0);
  });

  test('selector has options', async ({ page }) => {
    await page.goto(`${BASE_URL}${MAIN_ROUTES[0]}`);
    await page.waitForLoadState('networkidle');
    
    const selector = page.locator(SELECTOR_COMPONENT);
    if (await selector.isVisible()) {
      // Selector should have real option text, not empty
      const text = await selector.innerText();
      expect(text.trim().length).toBeGreaterThan(0);
    }
  });
});

// ============================================================================
// 3. AUTH SMOKE — User context visible
// ============================================================================
test.describe('Auth Smoke', () => {
  test('user identity visible after load', async ({ page }) => {
    await page.goto(`${BASE_URL}${MAIN_ROUTES[0]}`);
    await page.waitForLoadState('networkidle');
    
    // At least one of: avatar, user name, email, role badge should be visible
    const identitySelectors = [
      '[data-testid="user-avatar"]',
      '[data-testid="user-name"]',
      '[class*="avatar"]',
      '[class*="user"]',
    ];
    
    let found = false;
    for (const sel of identitySelectors) {
      if (await page.locator(sel).first().isVisible().catch(() => false)) {
        found = true;
        break;
      }
    }
    expect(found).toBe(true);
  });
});

// ============================================================================
// 4. CONSOLE ERROR CHECK — No unexpected errors
// ============================================================================
test.describe('Console Health', () => {
  test('no console.error on main route', async ({ page }) => {
    await page.goto(`${BASE_URL}${MAIN_ROUTES[0]}`);
    await page.waitForLoadState('networkidle');
    await page.waitForTimeout(2000);
    
    // Filter out known acceptable errors
    const realErrors = consoleErrors.filter(e => 
      !e.includes('favicon') && 
      !e.includes('DevTools') &&
      !e.includes('ResizeObserver')
    );
    
    if (realErrors.length > 0) {
      console.log('Console errors found:', realErrors);
    }
    expect(realErrors).toHaveLength(0);
  });
});

// ============================================================================
// 5. CSS VALIDATION — No broken variable references
// ============================================================================
test.describe('CSS Health', () => {
  test('no undefined CSS variables in computed styles', async ({ page }) => {
    await page.goto(`${BASE_URL}${MAIN_ROUTES[0]}`);
    await page.waitForLoadState('networkidle');
    
    // Check for elements with empty/broken CSS variable values
    const brokenVars = await page.evaluate(() => {
      const broken: string[] = [];
      document.querySelectorAll('*').forEach(el => {
        const style = getComputedStyle(el);
        // Check common properties that use CSS variables
        ['color', 'backgroundColor', 'borderColor'].forEach(prop => {
          const val = style.getPropertyValue(prop);
          if (val === '' || val === 'undefined') {
            broken.push(`${el.tagName}.${el.className}: ${prop}=${val}`);
          }
        });
      });
      return broken.slice(0, 10); // Limit output
    });
    
    expect(brokenVars).toHaveLength(0);
  });
});
